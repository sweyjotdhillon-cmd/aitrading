{
  "entities": {
    "Technique": {
      "title": "Technique",
      "description": "A trading technique or strategy.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["uid", "name", "description"]
    },
    "TradeAnalysis": {
      "title": "TradeAnalysis",
      "description": "A detailed analysis of a trade with feedback.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "stock": { "type": "string" },
        "signal": { "type": "string", "enum": ["CALL", "PUT", "NO TRADE"] },
        "market": { "type": "string", "enum": ["CLEAN", "DEAD", "CHAOTIC"] },
        "entry": { "type": "string", "enum": ["NOW", "WAIT"] },
        "probability": { "type": "number" },
        "result": { "type": "string", "enum": ["WIN", "LOSS"] },
        "followedRules": { "type": "boolean" },
        "mistakeType": { "type": "string", "enum": ["late entry", "bad market", "overtrade", "none"] },
        "notes": { "type": "string" },
        "analysisText": { "type": "string" },
        "bigInsight": { "type": "string" },
        "techniquesUsed": { "type": "string" },
        "notesUsed": { "type": "string" },
        "improvementsUsed": { "type": "string" },
        "investmentAmount": { "type": "number" },
        "profitAmount": { "type": "number" },
        "accountType": { "type": "string", "enum": ["REAL", "DEMO"] }
      },
      "required": ["uid", "timestamp", "stock", "signal", "market", "entry", "probability", "analysisText"]
    },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["admin", "user"] },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "createdAt": { "type": "number" }
        },
        "required": ["role", "email"]
      },
      "description": "User profile data."
    },
    "users/{userId}/techniques/{techniqueId}": {
      "schema": { "$ref": "#/entities/Technique" },
      "description": "Techniques created by a user."
    },
    "tradeAnalyses/{analysisId}": {
      "schema": { "$ref": "#/entities/TradeAnalysis" },
      "description": "Trade analyses and feedback."
    },
    "users/{userId}/stocks/{stockId}": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "createdAt": { "type": "number" }
        },
        "required": ["name", "createdAt"]
      },
      "description": "Custom stock list for the user."
    },
    "settings/{settingId}": {
      "schema": {
        "type": "object",
        "properties": {
          "adminPassword": { "type": "string" }
        }
      },
      "description": "Global application settings."
    }
  }
}
