rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/techniques
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - The user ID of the creator
    //   - name: string (required) - The name of the technique
    //   - description: string (required) - The description of the technique
    //   - code: string (optional) - The code associated with the technique
    //
    // Collection: tradeAnalyses/{analysisId}
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - The user ID of the creator
    //   - timestamp: string (required) - ISO 8601 timestamp
    //   - stock: string (required) - The name of the stock
    //   - signal: string (required) - CALL, PUT, or NO TRADE
    //   - market: string (required) - CLEAN, DEAD, or CHAOTIC
    //   - strength: string (required) - WEAK, MODERATE, or STRONG
    //   - entry: string (required) - NOW or WAIT
    //   - probability: number (required) - 0-100
    //   - analysisText: string (required) - The AI analysis text
    //   - bigInsight: string (optional) - Big insight text
    //   - techniquesUsed: string (optional) - Techniques used text
    //   - notesUsed: string (optional) - Notes used text
    //   - improvementsUsed: string (optional) - Improvements used text
    //   - investmentAmount: number (optional) - Investment amount
    //   - profitAmount: number (optional) - Profit amount
    //   - accountType: string (optional) - REAL or DEMO
    //
    // ===============================================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }
    
    // Verify UID hasn't been tampered with on create
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    // Ensure uid field is not modified on update
    function uidNotModified() {
      return !('uid' in request.resource.data) || 
             !('uid' in resource.data) || 
             request.resource.data.uid == resource.data.uid;
    }
    
    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidTechnique(data) {
      return (!('uid' in data) || data.uid == null || (data.uid is string && data.uid.size() > 0 && data.uid.size() < 100)) &&
             (!('name' in data) || data.name == null || (data.name is string && data.name.size() > 0 && data.name.size() <= 500)) &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() >= 0 && data.description.size() <= 100000)) &&
             (!('lz:description' in data) || data['lz:description'] == null || (data['lz:description'] is string)) &&
             (!('id' in data) || data.id == null || (data.id is string)) &&
             (!('code' in data) || data.code == null || (data.code is string && data.code.size() <= 100000)) &&
             (!('lz:code' in data) || data['lz:code'] == null || (data['lz:code'] is string));
    }

    function isValidTradeAnalysis(data) {
      return hasOnlyAllowedFields(data, ['id', 'uid', 'timestamp', 'stock', 'signal', 'market', 'strength', 'entry', 'probability', 'result', 'followedRules', 'mistakeType', 'notes', 'lz:notes', 'analysisText', 'lz:analysisText', 'graphTimeframe', 'investmentDuration', 'bigInsight', 'lz:bigInsight', 'techniquesUsed', 'lz:techniquesUsed', 'notesUsed', 'lz:notesUsed', 'improvementsUsed', 'lz:improvementsUsed', 'investmentAmount', 'profitAmount', 'accountType', 'structuredInsight', 'lz:structuredInsight', 'expiresAt', 'embedding', 'reason', 'createdAt', 'updatedAt']) &&
             (!('uid' in data) || data.uid == null || (data.uid is string && data.uid.size() > 0 && data.uid.size() < 100)) &&
             (!('id' in data) || data.id == null || (data.id is string)) &&
             (!('timestamp' in data) || data.timestamp == null || (data.timestamp is string || data.timestamp is number)) &&
             (!('stock' in data) || data.stock == null || (data.stock is string && data.stock.size() > 0 && data.stock.size() < 100)) &&
             (!('signal' in data) || data.signal == null || (data.signal in ['CALL', 'PUT', 'NO TRADE'])) &&
             (!('market' in data) || data.market == null || (data.market in ['CLEAN', 'DEAD', 'CHAOTIC'])) &&
             (!('strength' in data) || data.strength == null || (data.strength in ['WEAK', 'MODERATE', 'STRONG'])) &&
             (!('entry' in data) || data.entry == null || (data.entry in ['NOW', 'WAIT'])) &&
             (!('probability' in data) || data.probability == null || (data.probability is number && data.probability >= 0 && data.probability <= 100)) &&
             (!('result' in data) || data.result == null || (data.result in ['WIN', 'LOSS'])) &&
             (!('followedRules' in data) || data.followedRules == null || (data.followedRules is bool)) &&
             (!('mistakeType' in data) || data.mistakeType == null || (data.mistakeType in ['late entry', 'bad market', 'overtrade', 'none'])) &&
             (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() < 10000)) &&
             (!('lz:notes' in data) || data['lz:notes'] == null || (data['lz:notes'] is string)) &&
             (!('analysisText' in data) || data.analysisText == null || (data.analysisText is string && data.analysisText.size() > 0)) &&
             (!('lz:analysisText' in data) || data['lz:analysisText'] == null || (data['lz:analysisText'] is string)) &&
             (!('graphTimeframe' in data) || data.graphTimeframe == null || (data.graphTimeframe is string)) &&
             (!('investmentDuration' in data) || data.investmentDuration == null || (data.investmentDuration is string)) &&
             (!('bigInsight' in data) || data.bigInsight == null || (data.bigInsight is string)) &&
             (!('lz:bigInsight' in data) || data['lz:bigInsight'] == null || (data['lz:bigInsight'] is string)) &&
             (!('techniquesUsed' in data) || data.techniquesUsed == null || (data.techniquesUsed is string)) &&
             (!('lz:techniquesUsed' in data) || data['lz:techniquesUsed'] == null || (data['lz:techniquesUsed'] is string)) &&
             (!('notesUsed' in data) || data.notesUsed == null || (data.notesUsed is string)) &&
             (!('lz:notesUsed' in data) || data['lz:notesUsed'] == null || (data['lz:notesUsed'] is string)) &&
             (!('improvementsUsed' in data) || data.improvementsUsed == null || (data.improvementsUsed is string)) &&
             (!('lz:improvementsUsed' in data) || data['lz:improvementsUsed'] == null || (data['lz:improvementsUsed'] is string)) &&
             (!('investmentAmount' in data) || data.investmentAmount == null || (data.investmentAmount is number)) &&
             (!('profitAmount' in data) || data.profitAmount == null || (data.profitAmount is number)) &&
             (!('accountType' in data) || data.accountType == null || (data.accountType in ['REAL', 'DEMO'])) &&
             (!('structuredInsight' in data) || data.structuredInsight == null || (data.structuredInsight is map)) &&
             (!('lz:structuredInsight' in data) || data['lz:structuredInsight'] == null || (data['lz:structuredInsight'] is string)) &&
             (!('expiresAt' in data) || data.expiresAt == null || (data.expiresAt is number)) &&
             (!('embedding' in data) || data.embedding == null || (data.embedding is list && data.embedding.size() <= 2000)) &&
             (!('reason' in data) || data.reason == null || (data.reason is string && data.reason.size() < 5000));
    }

    function isValidBehaviorProfile(data) {
      return hasOnlyAllowedFields(data, ['currentStreak', 'maxStreak', 'totalWins', 'totalLosses', 'lastResult', 'commonMistakes', 'lz:commonMistakes']) &&
             (!('currentStreak' in data) || data.currentStreak is number) &&
             (!('maxStreak' in data) || data.maxStreak is number) &&
             (!('totalWins' in data) || data.totalWins is number) &&
             (!('totalLosses' in data) || data.totalLosses is number) &&
             (!('lastResult' in data) || data.lastResult == null || (data.lastResult in ['WIN', 'LOSS'])) &&
             (!('commonMistakes' in data) || data.commonMistakes is map) &&
             (!('lz:commonMistakes' in data) || data['lz:commonMistakes'] is string);
    }

    match /users/{userId}/techniques/{techniqueId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidTechnique(request.resource.data);
      allow update: if isOwner(userId) && isValidTechnique(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/stocks/{stockId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && hasOnlyAllowedFields(request.resource.data, ['role', 'email', 'name', 'createdAt']) && 
                      request.resource.data.createdAt is number &&
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && hasOnlyAllowedFields(request.resource.data, ['role', 'email', 'name', 'createdAt']) && 
                      (isAdmin() || (request.resource.data.role == resource.data.role && request.resource.data.createdAt == resource.data.createdAt));

      match /techniques/{techniqueId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasOnlyAllowedFields(request.resource.data, ['uid', 'name', 'description', 'lz:description', 'id', 'code', 'lz:code', 'createdAt', 'updatedAt', 'timestamp']) && isValidTechnique(request.resource.data);
        allow update: if isOwner(userId) && isValidTechnique(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId) || isAdmin();
      }
      match /appState/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /presence/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /stats/{document=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isValidBehaviorProfile(request.resource.data)) || isAdmin();
      }
    }

    match /tradeAnalyses/{analysisId} {
      allow list: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow get: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.uid == request.auth.uid) && isValidTradeAnalysis(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || (resource != null && (resource.data.uid == request.auth.uid || !('uid' in resource.data)))) && isValidTradeAnalysis(request.resource.data);
      allow delete: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.uid == request.auth.uid));
    }

    match /test/{docId} {
      allow read: if isAuthenticated();
    }

    match /settings/{settingId} {
      // Non-system settings are readable by any authenticated user.
      // settings/system contains encryptedTokens  restrict read to admins only.
      allow read: if settingId != 'system' && isAuthenticated() || isAdmin();
      // Allow admins to write anything
      // Allow any authenticated user to disable aiAccessMode if it's expired (30 min)
      allow update: if isAdmin() || (
        settingId == 'system' && 
        request.resource.data.aiAccessMode == false &&
        resource.data.aiAccessMode == true &&
        (request.time.toMillis() - resource.data.aiAccessModeEnabledAt) > (30 * 60 * 1000)
      );
      allow create: if isAdmin();
    }
  }
}
